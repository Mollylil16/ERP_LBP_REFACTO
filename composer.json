{
    "require-dev": {
        "phpunit/phpunit": "^12.5.8",
        "dbrekelmans/bdi": "^1.3",
        "symfony/panther": "^2.4"
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:unit": "phpunit --testsuite Unit",
        "test:feature": "phpunit --testsuite Feature",
        "smoke:admin": "php tests/Smoke/smoke_admin.php",
        "smoke:visibility": "php tests/Smoke/smoke_visibility.php",
        "smoke:employee": "php tests/Smoke/smoke_employee_portal.php"
    },
    "config": {
        "disable-tls": true,
        "secure-http": false
    }
}
