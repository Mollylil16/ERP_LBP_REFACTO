# Backend (exemple) — NE PAS mettre de secrets en git
#
# Copiez ce fichier vers `.env` et remplacez les valeurs.
#
# Database
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USERNAME=lbp_ci
DB_PASSWORD=CHANGE_ME
DB_DATABASE=lbp_db
DB_SYNCHRONIZE=false

# Application
PORT=3001
API_PREFIX=api
NODE_ENV=production

# URL(s)
APP_URL=https://app.example.com
FRONTEND_URL=https://app.example.com

# CORS (prod)
# Origines autorisées, séparées par virgule
# ex: "https://app.example.com,https://admin.example.com"
CORS_ORIGINS=https://app.example.com

# Forcer HTTPS (si TLS est terminé par NGINX/Traefik et x-forwarded-proto est renseigné)
FORCE_HTTPS=true

# JWT
JWT_SECRET=CHANGE_ME_LONG_RANDOM
JWT_EXPIRES_IN=1h

# Refresh token rotation
REFRESH_TOKEN_TTL_DAYS=7

# Sentry (optionnel)
SENTRY_DSN=

